{
  "mcpServers": {
    "weather-server": {
      "type": "stdio",
      "command": "python3",
      "args": ["${workspaceFolder}/mcp_server/weather_server.py"],
      "env": {
        "AWS_REGION": "${env:AWS_REGION}",
        "OPENWEATHER_API_KEY": "${env:OPENWEATHER_API_KEY}"
      },
      "envFile": "${workspaceFolder}/.env"
    }
  }
}
